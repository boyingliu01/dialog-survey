<div x-data="{ activeTab: 'basic' }" class="max-w-4xl mx-auto p-6">
  <div class="flex border-b border-gray-200 mb-4">
    <button @click="activeTab='basic'" :class="activeTab==='basic' ? 'text-indigo-600 border-b-2 border-indigo-500 font-medium' : 'text-gray-500'" class="px-4 py-2 text-sm">基本信息</button>
    <button @click="activeTab='stats'" :class="activeTab==='stats' ? 'text-indigo-600 border-b-2 border-indigo-500 font-medium' : 'text-gray-500'" class="px-4 py-2 text-sm">统计分析</button>
    <button @click="activeTab='members'" :class="activeTab==='members' ? 'text-indigo-600 border-b-2 border-indigo-500 font-medium' : 'text-gray-500'" class="px-4 py-2 text-sm">成员列表</button>
  </div>
  <div x-show="activeTab==='basic'" class="space-y-3 text-sm">
    <p><span class="text-gray-500">计划名称:</span> {{ plan.name }}</p>
    <p><span class="text-gray-500">关联模板:</span> <a href="/admin/content/templates/{{ template.id }}" hx-get="/admin/content/templates/{{ template.id }}" hx-target="#main-content" class="text-indigo-600 hover:underline">{{ template.name }}</a></p>
    <p><span class="text-gray-500">状态:</span> {{ plan.status }}</p>
    <p><span class="text-gray-500">进度:</span> {{ completedCount }}/{{ totalInterviews }} ({{ completionRate }}%)</p>
    {% if plan.description %}
    <p><span class="text-gray-500">描述:</span> {{ plan.description }}</p>
    {% endif %}
  </div>
  <div x-show="activeTab==='stats'" x-cloak class="text-sm">
    {% if completedCount == 0 %}
    <div class="text-center text-gray-400 py-8">暂无数据，完成访谈后可查看统计</div>
    {% else %}
    <div class="space-y-3">
      <p><span class="text-gray-500">已完成:</span> {{ completedCount }} 人</p>
      <p class="text-gray-400 text-xs italic">统计分析功能开发中...</p>
    </div>
    {% endif %}
  </div>
  <div x-show="activeTab==='members'" x-cloak class="text-sm">
    <table class="w-full">
      <thead><tr class="border-b"><th class="text-left py-2">被访者</th><th class="text-left py-2">状态</th><th class="text-left py-2">完成时间</th></tr></thead>
      <tbody>
        {% for interview in interviews %}
        <tr class="border-b">
          <td class="py-1.5">{{ interview.userId }}</td>
          <td class="py-1.5">{{ interview.status }}</td>
          <td class="py-1.5">{{ interview.completedAt | default('-') }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
