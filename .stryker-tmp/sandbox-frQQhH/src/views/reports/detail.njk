{% extends "layouts/admin.njk" %}

{% block content %}
<div class="mb-6">
  <a href="/admin/reports" class="text-blue-600 hover:text-blue-800 text-sm mb-2 inline-block">← 返回报告列表</a>
  <h1 class="text-2xl font-bold text-gray-900">访谈报告：{{ interview.userId }}</h1>
</div>

<div class="bg-white rounded-lg border p-6">
  <dl class="grid grid-cols-2 gap-4 mb-6">
    <div><dt class="text-sm font-medium text-gray-500">受访者</dt><dd class="mt-1 text-sm">{{ interview.userId }}</dd></div>
    <div><dt class="text-sm font-medium text-gray-500">状态</dt><dd class="mt-1"><span class="px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-800">{{ interview.status }}</span></dd></div>
    <div><dt class="text-sm font-medium text-gray-500">创建时间</dt><dd class="mt-1 text-sm">{{ interview.createdAtFormatted }}</dd></div>
    {% if report %}<div><dt class="text-sm font-medium text-gray-500">情感分析</dt><dd class="mt-1 text-sm">{{ report.sentiment or '-' }}</dd></div>{% endif %}
  </dl>

  {% if report %}
  <div class="border-t pt-4">
    <h2 class="text-lg font-semibold mb-3">报告内容</h2>
    <pre class="bg-gray-50 p-4 rounded-lg text-sm whitespace-pre-wrap max-h-96 overflow-y-auto">{{ report.content }}</pre>
  </div>
  {% if report.keyFindings and report.keyFindings | length > 0 %}
  <div class="mt-4"><h3 class="text-sm font-medium text-gray-700 mb-2">关键发现</h3><ul class="list-disc list-inside space-y-1">{% for f in report.keyFindings %}<li class="text-sm text-gray-700">{{ f }}</li>{% endfor %}</ul></div>
  {% endif %}
  {% if report.recommendations and report.recommendations | length > 0 %}
  <div class="mt-4"><h3 class="text-sm font-medium text-gray-700 mb-2">建议</h3><ul class="list-disc list-inside space-y-1">{% for r in report.recommendations %}<li class="text-sm text-gray-700">{{ r }}</li>{% endfor %}</ul></div>
  {% endif %}
  {% else %}
  <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 text-center">
    <p class="text-yellow-700">该访谈暂无报告。</p>
  </div>
  {% endif %}
</div>
{% endblock %}
