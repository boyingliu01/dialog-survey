{% extends "layouts/admin.njk" %}

{% block title %}统计分析{% endblock %}

{% block content %}
<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">统计分析</h1>
  <p class="text-sm text-gray-500 mt-1">跨计划汇总数据与趋势分析</p>
</div>

<!-- KPI Cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
  <div class="bg-white rounded-lg shadow-sm p-5">
    <p class="text-sm text-gray-500">总访谈数</p>
    <p class="text-2xl font-bold text-gray-900 mt-1">{{ kpis.totalInterviews }}</p>
  </div>
  <div class="bg-white rounded-lg shadow-sm p-5">
    <p class="text-sm text-gray-500">完成率</p>
    <p class="text-2xl font-bold text-blue-600 mt-1">{{ kpis.completionRate }}%</p>
  </div>
  <div class="bg-white rounded-lg shadow-sm p-5">
    <p class="text-sm text-gray-500">平均用时</p>
    <p class="text-2xl font-bold text-green-600 mt-1">{{ kpis.averageDurationMinutes }} min</p>
  </div>
  <div class="bg-white rounded-lg shadow-sm p-5">
    <p class="text-sm text-gray-500">访谈报告数</p>
    <p class="text-2xl font-bold text-purple-600 mt-1">{{ kpis.totalReports }}</p>
  </div>
</div>

<!-- Status Distribution & Weekly Trend -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
  <!-- Status Distribution -->
  <div class="bg-white rounded-lg shadow-sm p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">状态分布</h2>
    <div class="space-y-3">
      {% set statusColors = { "PENDING": "bg-gray-400", "ACTIVE": "bg-blue-500", "WAITING": "bg-yellow-400", "COMPLETED": "bg-green-500", "CANCELLED": "bg-red-500" } %}
      {% set statusLabels = { "PENDING": "待开始", "ACTIVE": "进行中", "WAITING": "等待回复", "COMPLETED": "已完成", "CANCELLED": "已取消" } %}
      {% set totalInterviews = kpis.totalInterviews %}
      {% for status in ["PENDING", "ACTIVE", "WAITING", "COMPLETED", "CANCELLED"] %}
        {% set count = statusDistribution[status] | default(0) %}
        {% set pct = 0 %}
        {% if totalInterviews > 0 %}
          {% set pct = (count / totalInterviews * 100) | round %}
        {% endif %}
        <div>
          <div class="flex justify-between text-sm mb-1">
            <span class="text-gray-600">{{ statusLabels[status] }}</span>
            <span class="font-medium text-gray-900">{{ count }} ({{ pct }}%)</span>
          </div>
          <div class="w-full bg-gray-200 rounded-full h-2.5">
            <div class="{{ statusColors[status] }} h-2.5 rounded-full" style="width: {{ pct }}%"></div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>

  <!-- Weekly Trend -->
  <div class="bg-white rounded-lg shadow-sm p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">每周趋势（近8周）</h2>
    {% set maxCount = 0 %}
    {% for entry in weeklyTrend %}
      {% if entry.count > maxCount %}
        {% set maxCount = entry.count %}
      {% endif %}
    {% endfor %}
    <div class="flex items-end gap-2 h-40">
      {% for entry in weeklyTrend %}
        {% set barHeight = 0 %}
        {% if maxCount > 0 %}
          {% set barHeight = (entry.count / maxCount * 100) | round %}
        {% endif %}
        <div class="flex flex-col items-center flex-1 min-w-0">
          <span class="text-xs text-gray-500 mb-1">{{ entry.count }}</span>
          <div class="w-full bg-blue-100 rounded-t-sm relative" style="height: 100px;">
            <div class="absolute bottom-0 left-0 right-0 bg-blue-500 rounded-t-sm transition-all" style="height: {{ barHeight }}%;"></div>
          </div>
          <span class="text-xs text-gray-400 mt-1 truncate w-full text-center">{{ entry.week | replace("W", "周") }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<!-- Plan Completion Rates -->
<div class="bg-white rounded-lg shadow-sm p-6 mb-8">
  <h2 class="text-lg font-semibold text-gray-900 mb-4">计划完成率</h2>
  {% if planCompletionRates.length > 0 %}
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead>
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">计划名称</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">总访谈</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">已完成</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">进度</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        {% for plan in planCompletionRates %}
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 text-sm font-medium text-gray-900">{{ plan.planName }}</td>
          <td class="px-4 py-3 text-sm text-gray-600">{{ plan.totalInterviews }}</td>
          <td class="px-4 py-3 text-sm text-gray-600">{{ plan.completedCount }}</td>
          <td class="px-4 py-3 text-sm">
            <div class="flex items-center gap-2">
              <div class="flex-1 bg-gray-200 rounded-full h-2">
                <div
                  class="h-2 rounded-full {% if plan.completionRate >= 80 %}bg-green-500{% elif plan.completionRate >= 50 %}bg-blue-500{% elif plan.completionRate >= 20 %}bg-yellow-500{% else %}bg-red-400{% endif %}"
                  style="width: {{ plan.completionRate }}%">
                </div>
              </div>
              <span class="text-xs text-gray-500 w-10 text-right">{{ plan.completionRate }}%</span>
            </div>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% else %}
  <p class="text-sm text-gray-500 text-center py-8">暂无计划数据</p>
  {% endif %}
</div>

<!-- Filter Controls -->
<div class="bg-white rounded-lg shadow-sm p-6">
  <h2 class="text-lg font-semibold text-gray-900 mb-4">筛选</h2>
  <div class="flex flex-wrap gap-3">
    <select id="filter-template" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      <option value="">选择模板</option>
      {% for t in templates %}
      <option value="{{ t.id }}">{{ t.name }}</option>
      {% endfor %}
    </select>
    <select id="filter-plan" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      <option value="">选择计划</option>
      {% for p in plans %}
      <option value="{{ p.id }}">{{ p.name }}</option>
      {% endfor %}
    </select>
    <button
      id="apply-filter"
      hx-get="/admin/api/analytics/data"
      hx-target="#analytics-content"
      hx-swap="innerHTML"
      class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
      应用筛选
    </button>
  </div>
</div>
{% endblock %}
