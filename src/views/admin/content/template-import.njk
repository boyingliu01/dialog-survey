<!-- template-import.njk -- JSON import form -->
<div class="p-4 border-b border-gray-100 bg-white">
  <div class="flex items-center justify-between mb-3">
    <h3 class="text-sm font-semibold text-gray-800">导入模板</h3>
    <button
      hx-get="/admin/content/dashboard"
      hx-target="#main-content"
      hx-swap="innerHTML"
      class="text-gray-400 hover:text-gray-600"
      title="取消"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>
  <form
    hx-post="/admin/api/templates/import"
    hx-target="#form-result"
    hx-swap="innerHTML"
    hx-indicator="#submit-btn"
    hx-on::after-request="if (event.detail.successful) { htmx.ajax('GET', '/admin', {target: '#main-content', swap: 'innerHTML'}); }"
    class="space-y-3"
  >
    <div>
      <label for="json" class="block text-xs font-medium text-gray-600 mb-1">
        JSON 内容 <span class="text-red-500">*</span>
      </label>
      <textarea id="json" name="json" required rows="14"
                class="block w-full text-sm rounded-md border border-gray-300 px-2 py-1.5 focus:border-indigo-500 focus:ring-indigo-500 resize-none font-mono"
                placeholder='{
  "name": "模板名称",
  "description": "可选描述",
  "content": {
    "invitationPrompt": "邀约提示词",
    "questions": ["问题1", "问题2"],
    "closingMessage": "结束语（可选）",
    "llmPromptTemplate": "AI提示词模板（可选）"
  },
  "dimensions": [
    {"id": "dim1", "label": "维度1", "keywords": ["关键词1", "关键词2"]}
  ]
}'></textarea>
      <p class="text-xs text-gray-400 mt-1">粘贴从导出接口获取的模板 JSON，或按上方格式构建。支持邀约提示词、问题列表、结束语、AI提示词模板和维度标签。</p>
    </div>
    <div class="flex justify-end gap-2 pt-1">
      <button type="submit" id="submit-btn"
              class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-white bg-indigo-600 rounded-md hover:bg-indigo-700 focus:ring-2 focus:ring-indigo-500 disabled:opacity-50">
        <span class="htmx-indicator hidden mr-1.5">
          <svg class="animate-spin h-3 w-3 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </span>
        导入
      </button>
    </div>
  </form>
  <div id="form-result" class="mt-2"></div>
</div>
