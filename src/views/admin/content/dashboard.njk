<div x-data="{ activeTab: 'dashboard' }" class="max-w-6xl">
  <!-- Tab Navigation -->
  <div class="mb-6 border-b border-gray-200">
    <div class="flex gap-6">
      <button
        @click="activeTab = 'dashboard'; htmx.ajax('GET', '/admin/content/dashboard', {target: '#main-content', swap: 'innerHTML'})"
        class="pb-3 text-sm font-medium border-b-2 transition-colors"
        :class="activeTab === 'dashboard' ? 'text-indigo-600 border-indigo-600' : 'text-gray-500 border-transparent hover:text-gray-700'"
      >
        计划进度
      </button>
      <a
        href="/admin/analytics"
        class="pb-3 text-sm font-medium text-gray-500 border-b-2 border-transparent hover:text-gray-700 transition-colors"
      >
        统计分析
      </a>
    </div>
  </div>

  {% if plans.length > 0 %}
  <!-- Plan Progress Cards -->
  <div class="space-y-4">
    {% for plan in plans %}
    <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden">
      <!-- Plan Header -->
      <div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between">
        <div>
          <h3 class="text-sm font-semibold text-gray-900">
            <a href="/admin/content/plans/{{ plan.planId }}" class="hover:text-indigo-600"
               hx-get="/admin/content/plans/{{ plan.planId }}"
               hx-target="#main-content"
               hx-swap="innerHTML"
               @click.prevent="htmx.ajax('GET', '/admin/content/plans/{{ plan.planId }}', {target: '#main-content', swap: 'innerHTML'})"
            >{{ plan.planName }}</a>
          </h3>
          <p class="text-xs text-gray-400 mt-0.5">{{ plan.templateName }}</p>
        </div>
        <div class="text-right">
          <span class="text-lg font-bold {% if plan.progressPercentage >= 80 %}text-green-600{% elif plan.progressPercentage >= 50 %}text-blue-600{% elif plan.progressPercentage >= 20 %}text-yellow-600{% else %}text-red-400{% endif %}">
            {{ plan.progressPercentage }}%
          </span>
          <p class="text-xs text-gray-400">完成率</p>
        </div>
      </div>

      <!-- Progress Bar -->
      <div class="px-5 py-3">
        <div class="w-full bg-gray-100 rounded-full h-2.5">
          <div
            class="h-2.5 rounded-full transition-all duration-500 {% if plan.progressPercentage >= 80 %}bg-green-500{% elif plan.progressPercentage >= 50 %}bg-blue-500{% elif plan.progressPercentage >= 20 %}bg-yellow-500{% else %}bg-red-400{% endif %}"
            style="width: {{ plan.progressPercentage }}%">
          </div>
        </div>
      </div>

      <!-- Status Breakdown -->
      <div class="px-5 py-3 bg-gray-50 flex items-center gap-6 text-xs">
        <div>
          <span class="font-medium text-gray-700">{{ plan.total }}</span>
          <span class="text-gray-400 ml-1">总计</span>
        </div>
        <div>
          <span class="font-medium text-green-600">{{ plan.completed }}</span>
          <span class="text-gray-400 ml-1">已完成</span>
        </div>
        <div>
          <span class="font-medium text-blue-600">{{ plan.inProgress }}</span>
          <span class="text-gray-400 ml-1">进行中</span>
        </div>
        <div>
          <span class="font-medium text-yellow-600">{{ plan.waiting }}</span>
          <span class="text-gray-400 ml-1">等待回复</span>
        </div>
        <div>
          <span class="font-medium text-gray-500">{{ plan.notStarted }}</span>
          <span class="text-gray-400 ml-1">待开始</span>
        </div>
        <div>
          <span class="font-medium text-red-400">{{ plan.cancelled }}</span>
          <span class="text-gray-400 ml-1">已取消</span>
        </div>
      </div>
    </div>
    {% endfor %}
  </div>
  {% else %}
  <!-- Empty State -->
  <div class="flex flex-col items-center justify-center py-16 text-gray-400">
    <svg class="w-16 h-16 mb-4 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
    </svg>
    <p class="text-sm">暂无访谈计划数据</p>
    <p class="text-xs mt-1 text-gray-300">创建访谈计划后，进度将在此展示</p>
  </div>
  {% endif %}
</div>
