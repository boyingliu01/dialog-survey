<style>
.report-content h1 { font-size: 1.25rem; font-weight: 700; color: #1f2937; margin: 1.25rem 0 0.75rem; padding-bottom: 0.375rem; border-bottom: 1px solid #e5e7eb; }
.report-content h2 { font-size: 1.1rem; font-weight: 600; color: #374151; margin: 1rem 0 0.5rem; display: flex; align-items: center; gap: 0.5rem; }
.report-content h2::before { content: ''; display: inline-block; width: 4px; height: 1rem; background: linear-gradient(to bottom, #6366f1, #8b5cf6); border-radius: 2px; }
.report-content h3 { font-size: 1rem; font-weight: 600; color: #4b5563; margin: 0.75rem 0 0.375rem; }
.report-content p { color: #4b5563; line-height: 1.7; margin: 0.5rem 0; }
.report-content ul, .report-content ol { margin: 0.5rem 0; padding-left: 1.5rem; }
.report-content li { color: #4b5563; line-height: 1.7; margin: 0.25rem 0; }
.report-content ul li { list-style-type: disc; }
.report-content ol li { list-style-type: decimal; }
.report-content strong { color: #1f2937; font-weight: 600; }
.report-content em { color: #6b7280; font-style: italic; }
.report-content blockquote { border-left: 3px solid #8b5cf6; background: #f5f3ff; padding: 0.5rem 1rem; margin: 0.75rem 0; border-radius: 0 0.375rem 0.375rem 0; }
.report-content blockquote p { color: #6d28d9; margin: 0; }
.report-content code { background: #f3f4f6; padding: 0.125rem 0.375rem; border-radius: 0.25rem; font-size: 0.875rem; color: #7c3aed; }
.report-content hr { border: none; border-top: 1px solid #e5e7eb; margin: 1rem 0; }
.report-content > *:first-child { margin-top: 0; }
.report-content > *:last-child { margin-bottom: 0; }
</style>

<div class="max-w-4xl mx-auto p-6">
  <div class="flex items-start justify-between mb-2">
    <div>
      <h2 class="text-lg font-semibold text-gray-800">
        访谈报告{% if inviteeInfo.name %} — {{ inviteeInfo.name }}{% elif interview.userId %} — {{ interview.userId }}{% endif %}
      </h2>
      <div class="text-sm text-gray-500 mt-1 space-x-3">
        <span>用户: {{ interview.userId }}</span>
        {% if inviteeInfo.name %}<span>姓名: <strong>{{ inviteeInfo.name }}</strong></span>{% endif %}
        {% if inviteeInfo.phone %}<span>电话: <strong>{{ inviteeInfo.phone }}</strong></span>{% endif %}
        <span>状态: {{ interview.status }}</span>
      </div>
    </div>
    {% if report %}
    <div class="flex gap-2">
      <button
        id="reanalyze-btn"
        onclick="reanalyzeInterview('{{ interview.id }}')"
        class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-white bg-purple-600 rounded-md hover:bg-purple-700 disabled:opacity-50 disabled:cursor-not-allowed"
      >
        <span id="reanalyze-text">重新分析</span>
      </button>
      <a
        href="/admin/api/reports/{{ interview.id }}/export/pdf"
        class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-white bg-red-600 rounded-md hover:bg-red-700"
        download
      >导出 PDF</a>
      <a
        href="/admin/api/reports/{{ interview.id }}/export/excel"
        class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-white bg-green-600 rounded-md hover:bg-green-700"
        download
      >导出 Excel</a>
      <a
        href="/admin/api/reports/{{ interview.id }}/download"
        class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700"
        download
      >下载报告 (.md)</a>
    </div>
    {% endif %}
  </div>

  <div class="text-sm space-y-2 mb-4">
    <p><span class="text-gray-500">创建时间:</span> {{ interview.createdAt | default('-') }}</p>
  </div>

  {# --- Dialog Section --- #}
  <div class="mt-6">
    <h3 class="text-md font-semibold text-gray-700 mb-3 border-b pb-1">访谈对话记录</h3>
    {% if interview.messages and interview.messages.length %}
    <div class="space-y-3">
      {% for m in interview.messages %}
      <div class="flex {% if m.role === 'assistant' %}justify-start{% else %}justify-end{% endif %}">
        <div class="{% if m.role === 'assistant' %}bg-blue-50 border-blue-200{% else %}bg-green-50 border-green-200{% endif %} border rounded-lg px-4 py-2 max-w-[85%]">
          <div class="text-xs font-medium mb-1 {% if m.role === 'assistant' %}text-blue-600{% else %}text-green-600{% endif %}">
            {% if m.role === 'assistant' %}🤖 机器人{% else %}👤 受访者{% endif %}
          </div>
          <div class="text-sm text-gray-800 whitespace-pre-wrap">{{ m.content }}</div>
        </div>
      </div>
      {% endfor %}
    </div>
    {% else %}
    <p class="text-gray-400 text-sm">暂无对话记录</p>
    {% endif %}
  </div>

  {# --- Analysis Summary Section --- #}
  {% if report %}
  <div class="mt-8">
    <h3 class="text-md font-semibold text-gray-700 mb-3 border-b pb-1">访谈分析总结</h3>
    
    {# 报告内容卡片 #}
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
      {# 报告头部 #}
      <div class="bg-gradient-to-r from-indigo-500 to-purple-600 px-5 py-3">
        <div class="flex items-center gap-2 text-white">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          <span class="text-sm font-medium">分析报告</span>
          {% if report.usedLLM %}
          <span class="ml-auto text-xs bg-white/20 px-2 py-0.5 rounded-full">AI 生成</span>
          {% endif %}
        </div>
      </div>
      {# 报告正文 #}
      <div class="report-content px-5 py-4">
        {{ report.content | markdown | safe }}
      </div>
    </div>

    {# 分析结果网格 #}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-4">
      {# 情感分析 #}
      {% if report.sentiment %}
      <div class="bg-white border border-gray-200 rounded-lg p-4 shadow-sm">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-lg">
            {% if report.sentiment === 'positive' %}😊
            {% elif report.sentiment === 'negative' %}😔
            {% else %}😐{% endif %}
          </span>
          <span class="text-sm font-medium text-gray-700">情感分析</span>
        </div>
        <div class="text-base font-semibold {% if report.sentiment === 'positive' %}text-green-600{% elif report.sentiment === 'negative' %}text-red-600{% else %}text-gray-600{% endif %}">
          {% if report.sentiment === 'positive' %}积极
          {% elif report.sentiment === 'negative' %}消极
          {% else %}中性{% endif %}
        </div>
      </div>
      {% endif %}

      {# 关键发现 #}
      {% if report.keyFindings and report.keyFindings.length %}
      <div class="bg-white border border-gray-200 rounded-lg p-4 shadow-sm">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-lg">💡</span>
          <span class="text-sm font-medium text-gray-700">关键发现</span>
        </div>
        <ul class="space-y-1.5 text-sm text-gray-700">
          {% for f in report.keyFindings %}
          <li class="flex items-start gap-2">
            <span class="text-blue-500 mt-0.5">•</span>
            <span>{{ f }}</span>
          </li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}

      {# 建议 #}
      {% if report.recommendations and report.recommendations.length %}
      <div class="bg-white border border-gray-200 rounded-lg p-4 shadow-sm">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-lg">📋</span>
          <span class="text-sm font-medium text-gray-700">建议</span>
        </div>
        <ul class="space-y-1.5 text-sm text-gray-700">
          {% for r in report.recommendations %}
          <li class="flex items-start gap-2">
            <span class="text-green-500 mt-0.5">✓</span>
            <span>{{ r }}</span>
          </li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}
    </div>
  </div>
  {% else %}
  <div class="text-center text-gray-400 py-8">暂无分析报告</div>
  {% endif %}
</div>

<script>
function showToast(msg, isError) {
  var t = document.createElement('div');
  t.className = 'fixed top-14 right-3 z-50 text-sm px-4 py-2.5 rounded-lg shadow-lg max-w-sm transition-all whitespace-pre-line';
  t.style.opacity = '0';
  t.style.transform = 'translateX(100%)';
  if (isError) {
    t.classList.add('bg-red-50', 'border', 'border-red-200', 'text-red-700');
  } else {
    t.classList.add('bg-green-50', 'border', 'border-green-200', 'text-green-700');
  }
  t.textContent = msg;
  document.body.appendChild(t);
  requestAnimationFrame(function() { t.style.opacity = '1'; t.style.transform = 'translateX(0)'; });
  setTimeout(function() {
    t.style.opacity = '0';
    t.style.transform = 'translateX(100%)';
    setTimeout(function() { t.remove(); }, 300);
  }, 5000);
}

function reanalyzeInterview(interviewId) {
  var btn = document.getElementById('reanalyze-btn');
  var txt = document.getElementById('reanalyze-text');
  btn.disabled = true;
  var startTime = Date.now();
  var timerInterval = setInterval(function() {
    var elapsed = Math.floor((Date.now() - startTime) / 1000);
    txt.innerHTML = '<svg class="animate-spin -ml-1 mr-1 h-3 w-3 text-white inline" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> 分析中... (' + elapsed + 's)';
  }, 1000);

  var controller = new AbortController();
  var timeoutId = setTimeout(function() { controller.abort(); }, 300000);

  fetch('/admin/api/reports/' + interviewId + '/reanalyze', {
    method: 'POST',
    headers: { 'X-Admin-Key': '{{ adminApiKey | default("") }}' },
    signal: controller.signal
  }).then(function(res) {
    clearTimeout(timeoutId);
    if (!res.ok) {
      return res.text().then(function(text) {
        try {
          var errData = JSON.parse(text);
          throw new Error(errData.error || ('HTTP ' + res.status));
        } catch (e) {
          if (e.message && !e.message.startsWith('Unexpected')) throw e;
          throw new Error('HTTP ' + res.status + ': ' + text.substring(0, 200));
        }
      });
    }
    return res.json();
  }).then(function(data) {
    clearInterval(timerInterval);
    var sentimentLabel = { positive: '积极', negative: '消极', neutral: '中立' };
    var summary = '✅ 分析完成';
    if (data.usedLLM) {
      summary += ' [LLM]';
    } else {
      summary += ' [降级模式]';
    }
    if (data.sentiment) summary += '（情绪: ' + (sentimentLabel[data.sentiment] || data.sentiment) + '）';
    if (data.keyFindingsCount !== undefined) summary += '\n' + data.keyFindingsCount + ' 条关键发现';
    if (data.recommendationsCount !== undefined) summary += '，' + data.recommendationsCount + ' 条建议';
    if (data.contentLength !== undefined) summary += '\n内容长度: ' + data.contentLength + ' 字符';
    showToast(summary, false);
    setTimeout(function() {
      htmx.ajax('GET', '/admin/content/reports/' + interviewId, { target: '#main-content', swap: 'innerHTML' });
    }, 500);
    btn.disabled = false;
    txt.textContent = '重新分析';
    btn.classList.remove('animate-pulse');
  }).catch(function(err) {
    clearInterval(timerInterval);
    clearTimeout(timeoutId);
    var msg = err.name === 'AbortError' ? '请求超时（5分钟），请检查 LLM 服务是否正常' : err.message;
    showToast('❌ 分析失败: ' + msg, true);
    btn.disabled = false;
    txt.textContent = '重新分析';
    btn.classList.remove('animate-pulse');
  });
}
</script>
