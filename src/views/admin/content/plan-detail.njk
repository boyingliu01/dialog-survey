{% if not plan %}
  <div class="p-6 text-red-600">Error: Plan data is missing.</div>
{% else %}
<div x-data="{
  activeTab: 'basic',
  showDeleteDialog: false,
  deleteStep: 1,
  deleteConfirmText: '',
  executeDelete(planId) {
    this.deleteStep = 3;
    const adminKey = document.getElementById('admin-api-key')?.dataset.key || '';
    fetch('/admin/api/plans/' + planId + '?force=true', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json', 'X-Admin-Key': adminKey, 'HX-Request': 'true' },
    })
    .then(r => {
      if (!r.ok) {
        return r.text().then(msg => { throw new Error(msg || 'Delete failed'); });
      }
      return r.text();
    })
    .then(() => {
      htmx.ajax('GET', '/admin/content/plans/' + planId, '#main-content');
      this.showDeleteDialog = false;
      this.deleteStep = 1;
      this.deleteConfirmText = '';
    })
    .catch(err => {
      alert('删除失败：' + err.message);
      this.deleteStep = 2;
    });
  }
}" class="max-w-4xl mx-auto p-6">
<span id="admin-api-key" data-key="{{ adminApiKey | default('') }}" class="hidden"></span>
  <div class="flex items-center justify-between mb-4">
    <div class="flex border-b border-gray-200">
      <button @click="activeTab='basic'" :class="activeTab==='basic' ? 'text-indigo-600 border-b-2 border-indigo-500 font-medium' : 'text-gray-500'" class="px-4 py-2 text-sm">基本信息</button>
      <button @click="activeTab='stats'" :class="activeTab==='stats' ? 'text-indigo-600 border-b-2 border-indigo-500 font-medium' : 'text-gray-500'" class="px-4 py-2 text-sm">统计分析</button>
      <button @click="activeTab='members'" :class="activeTab==='members' ? 'text-indigo-600 border-b-2 border-indigo-500 font-medium' : 'text-gray-500'" class="px-4 py-2 text-sm">成员列表</button>
    </div>
    <div class="flex gap-2">
      <button
        hx-get="/admin/content/plans/{{ plan.id }}/edit"
        hx-target="#main-content"
        hx-swap="innerHTML"
        hx-push-url="true"
        class="inline-flex items-center px-2.5 py-1 text-xs font-medium text-indigo-600 bg-indigo-50 rounded-md hover:bg-indigo-100"
      >
        <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
        编辑
      </button>
      {% if plan.status == 'PENDING' or plan.status == 'READY' %}
      <button
        hx-post="/api/plans/{{ plan.id }}/send"
        hx-target="#main-content"
        hx-swap="innerHTML"
        hx-confirm="确认发送访谈邀约？将向 {{ totalInterviews or 0 }} 位受访者发送钉钉消息。"
        class="inline-flex items-center px-2.5 py-1 text-xs font-medium text-emerald-600 bg-emerald-50 rounded-md hover:bg-emerald-100"
      >
        <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
        </svg>
        发送邀约
      </button>
      {% endif %}
      <button
        @click="showDeleteDialog=true; deleteStep=1; deleteConfirmText=''"
        class="inline-flex items-center px-2.5 py-1 text-xs font-medium text-red-600 bg-red-50 rounded-md hover:bg-red-100"
      >
        <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
        删除
      </button>
    </div>
  </div>

  <template x-if="showDeleteDialog">
    <div class="fixed inset-0 bg-black/50 flex items-center justify-center z-50" @click.self="showDeleteDialog=false">
      <div class="bg-white rounded-lg shadow-xl max-w-md w-full mx-4 p-6">
        <template x-if="deleteStep === 1">
          <div>
            <h3 class="text-lg font-medium text-gray-900 mb-3">⚠️ 高风险操作确认</h3>
            <p class="text-gray-600 mb-2">该访谈计划已关联 <strong class="text-gray-900">{{ totalInterviews or 0 }}</strong> 条访谈记录。</p>
            <p class="text-gray-600 mb-4">删除计划将同时删除这些访谈记录和相关批量报告，且<span class="text-red-600 font-medium">无法恢复</span>。</p>
            <div class="flex justify-end gap-2">
              <button @click="showDeleteDialog=false" class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-md hover:bg-gray-200">取消</button>
              <button @click="deleteStep=2; deleteConfirmText=''" class="px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-md hover:bg-red-700">继续</button>
            </div>
          </div>
        </template>
        <template x-if="deleteStep === 2">
          <div>
            <h3 class="text-lg font-medium text-red-600 mb-3">⚠️ 最终确认</h3>
            <p class="text-red-600 text-sm mb-3 font-medium">此操作将删除 <strong>{{ totalInterviews or 0 }}</strong> 条访谈记录，且无法恢复。</p>
            <p class="text-gray-600 text-sm mb-2">请在下方输入框中完整输入以下文字以确认：</p>
            <p class="text-gray-800 text-sm font-mono bg-gray-50 p-2 rounded border border-gray-200 mb-3 select-all" id="deleteConfirmPhrase">我确认要删除此计划及其关联的所有访谈记录</p>
            <input
              x-model="deleteConfirmText"
              type="text"
              placeholder="输入确认文字"
              class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
              @keydown.enter="deleteConfirmText === '我确认要删除此计划及其关联的所有访谈记录' && executeDelete('{{ plan.id }}')"
            />
            <div class="flex justify-end gap-2 mt-4">
              <button @click="showDeleteDialog=false; deleteStep=1; deleteConfirmText=''" class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-md hover:bg-gray-200">取消</button>
              <button
                :disabled="deleteConfirmText !== '我确认要删除此计划及其关联的所有访谈记录'"
                @click="executeDelete('{{ plan.id }}')"
                :class="deleteConfirmText === '我确认要删除此计划及其关联的所有访谈记录' ? 'text-white bg-red-600 hover:bg-red-700' : 'text-gray-400 bg-gray-200 cursor-not-allowed'"
                class="px-4 py-2 text-sm font-medium rounded-md"
              >确认删除</button>
            </div>
          </div>
        </template>
        <template x-if="deleteStep === 3">
          <div>
            <h3 class="text-lg font-medium text-gray-900 mb-3">正在删除...</h3>
            <div class="flex items-center justify-center py-6">
              <svg class="animate-spin h-8 w-8 text-indigo-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
            </div>
          </div>
        </template>
      </div>
    </div>
  </template>
  <div x-show="activeTab==='basic'" class="space-y-3 text-sm">
    <p><span class="text-gray-500">计划名称:</span> {{ plan.name }}</p>
    <p><span class="text-gray-500">关联模板:</span> {% if template %}<a href="/admin/content/templates/{{ template.id }}" hx-get="/admin/content/templates/{{ template.id }}" hx-target="#main-content" class="text-indigo-600 hover:underline">{{ template.name }}</a>{% else %}<span class="text-gray-400">模板已删除或不可用</span>{% endif %}</p>
    <p>
      <span class="text-gray-500">状态:</span>
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
        {% if plan.status == 'COMPLETED' %}bg-green-100 text-green-800
        {% elif plan.status == 'RUNNING' %}bg-blue-100 text-blue-800
        {% elif plan.status == 'PENDING' %}bg-gray-100 text-gray-800
        {% elif plan.status == 'READY' %}bg-yellow-100 text-yellow-800
        {% elif plan.status == 'PAUSED' %}bg-orange-100 text-orange-800
        {% elif plan.status == 'CANCELLED' %}bg-red-100 text-red-800
        {% else %}bg-gray-100 text-gray-800{% endif %}">
        {% if plan.status == 'COMPLETED' %}已完成
        {% elif plan.status == 'RUNNING' %}进行中
        {% elif plan.status == 'PENDING' %}待处理
        {% elif plan.status == 'READY' %}就绪
        {% elif plan.status == 'PAUSED' %}已暂停
        {% elif plan.status == 'CANCELLED' %}已取消
        {% else %}{{ plan.status }}{% endif %}
      </span>
    </p>
    <p><span class="text-gray-500">截止日期:</span> {% if plan.targetDate %}{{ plan.targetDate.toISOString().split('T')[0] }}{% else %}未设置{% endif %}</p>
    <p><span class="text-gray-500">进度:</span> {{ completedCount or 0 }}/{{ totalInterviews or 0 }} ({{ completionRate or 0 }}%)</p>
    {% if plan.description %}
    <p><span class="text-gray-500">描述:</span> {{ plan.description }}</p>
    {% endif %}
  </div>
  <div x-show="activeTab==='stats'" x-cloak class="text-sm">
    {% if not planStats or planStats.totalInterviews == 0 %}
    <div class="text-center text-gray-400 py-8">暂无数据，完成访谈后可查看统计</div>
    {% else %}
    <div class="space-y-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        <div class="border rounded p-3 bg-gray-50">
          <div class="text-xs text-gray-500">总成员数</div>
          <div class="text-lg font-semibold">{{ planStats.totalInterviews }}</div>
        </div>
        <div class="border rounded p-3 bg-gray-50">
          <div class="text-xs text-gray-500">已完成</div>
          <div class="text-lg font-semibold text-emerald-600">{{ planStats.completedCount }}</div>
        </div>
        <div class="border rounded p-3 bg-gray-50">
          <div class="text-xs text-gray-500">完成率</div>
          <div class="text-lg font-semibold">{{ planStats.completionRate }}%</div>
        </div>
        <div class="border rounded p-3 bg-gray-50">
          <div class="text-xs text-gray-500">平均访谈时长</div>
          <div class="text-lg font-semibold">{{ planStats.averageDurationMinutes }} 分钟</div>
        </div>
      </div>
      <div>
        <h4 class="text-xs font-medium text-gray-600 mb-2">状态分布</h4>
        <div class="grid grid-cols-2 md:grid-cols-5 gap-2">
          <div class="border rounded p-2 text-center">
            <div class="text-xs text-gray-500">待发送</div>
            <div class="font-semibold">{{ planStats.statusDistribution.PENDING }}</div>
          </div>
          <div class="border rounded p-2 text-center">
            <div class="text-xs text-gray-500">进行中</div>
            <div class="font-semibold">{{ planStats.statusDistribution.ACTIVE }}</div>
          </div>
          <div class="border rounded p-2 text-center">
            <div class="text-xs text-gray-500">等待回复</div>
            <div class="font-semibold">{{ planStats.statusDistribution.WAITING }}</div>
          </div>
          <div class="border rounded p-2 text-center">
            <div class="text-xs text-gray-500">已完成</div>
            <div class="font-semibold text-emerald-600">{{ planStats.statusDistribution.COMPLETED }}</div>
          </div>
          <div class="border rounded p-2 text-center">
            <div class="text-xs text-gray-500">已取消</div>
            <div class="font-semibold text-gray-400">{{ planStats.statusDistribution.CANCELLED }}</div>
          </div>
        </div>
      </div>
    </div>
    {% endif %}
  </div>
  <div x-show="activeTab==='members'" x-cloak class="text-sm" x-data="{ showAdd: false, newUserId: '', newPhone: '', newName: '' }">
    <div class="flex gap-2 mb-3">
      {% if plan.status == 'PENDING' or plan.status == 'READY' %}
      <button
        hx-post="/api/plans/{{ plan.id }}/send"
        hx-target="#main-content"
        hx-swap="innerHTML"
        hx-confirm="确认向所有未发送成员发送访谈邀约？"
        class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-white bg-emerald-600 rounded-md hover:bg-emerald-700"
      >批量发送邀约</button>
      {% endif %}
      <button
        @click="showAdd = !showAdd"
        class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-white bg-indigo-600 rounded-md hover:bg-indigo-700"
        type="button"
      >添加成员</button>
      <button
        hx-post="/api/plans/{{ plan.id }}/remind"
        hx-swap="none"
        hx-confirm="确认向所有未完成成员发送提醒？"
        hx-headers='{"Content-Type": "application/json", "X-Admin-Key": "{{ adminApiKey | default('') }}"}'
        hx-vals='{}'
        hx-on::after-request="if(event.detail.successful){htmx.ajax('GET','/admin/content/plans/{{ plan.id }}','#main-content')}"
        class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-white bg-amber-600 rounded-md hover:bg-amber-700"
      >批量提醒</button>
    </div>
    <div x-show="showAdd" x-cloak class="mb-3 p-3 border rounded bg-gray-50 flex gap-2 items-end">
      <div class="flex-1">
        <label class="block text-xs text-gray-500 mb-1">钉钉 ID</label>
        <input
          x-model="newUserId"
          type="text"
          class="w-full border rounded px-2 py-1 text-sm"
          placeholder="userId（与手机号二选一）"
        />
      </div>
      <div class="flex-1">
        <label class="block text-xs text-gray-500 mb-1">手机号</label>
        <input
          x-model="newPhone"
          type="text"
          inputmode="tel"
          class="w-full border rounded px-2 py-1 text-sm"
          placeholder="如：13800138000 或 +86-13800138000"
        />
        <p class="text-xs text-gray-400 mt-1">支持多种格式：11位手机号、+86-手机号</p>
      </div>
      <div class="flex-1">
        <label class="block text-xs text-gray-500 mb-1">姓名</label>
        <input
          x-model="newName"
          type="text"
          class="w-full border rounded px-2 py-1 text-sm"
          placeholder="姓名"
        />
      </div>
      <button
        type="button"
        @click="
          if (!newUserId && !newPhone) { alert('请填写钉钉 ID 或手机号'); return; }
          if (!newName) { alert('请填写姓名'); return; }
          var values = { name: newName };
          if (newUserId) { values.userId = newUserId; }
          if (newPhone) { values.phone = newPhone; }
          htmx.ajax('POST', '/api/plans/{{ plan.id }}/members', {
            swap: 'none',
            values: values,
            headers: { 'Content-Type': 'application/json', 'X-Admin-Key': '{{ adminApiKey | default('') }}' }
          }).then(function(xhr) {
            if (xhr.xhr && xhr.xhr.status >= 200 && xhr.xhr.status < 300) {
              htmx.ajax('GET', '/admin/content/plans/{{ plan.id }}', '#main-content');
            } else {
              alert('添加成员失败');
            }
          });
        "
        class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-white bg-emerald-600 rounded-md hover:bg-emerald-700"
      >确认添加</button>
      <button
        type="button"
        @click="showAdd = false; newUserId = ''; newPhone = ''; newName = ''"
        class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-gray-700 bg-gray-200 rounded-md hover:bg-gray-300"
      >取消</button>
    </div>
    <div x-show="showAdd" @click.away="showAdd = false; newUserId = ''; newPhone = ''; newName = ''" x-cloak>
    </div>
    <table class="w-full">
      <thead><tr class="border-b">
        <th class="text-left py-2">被访者</th>
        <th class="text-left py-2">发送状态</th>
        <th class="text-left py-2">访谈状态</th>
        <th class="text-left py-2">完成时间</th>
        <th class="text-left py-2">操作</th>
      </tr></thead>
      <tbody>
        {% for interview in (interviews or []) %}
        <tr class="border-b">
          <td class="py-1.5">
            {% if inviteeMap and inviteeMap[interview.userId] %}
              <span class="font-medium">{{ inviteeMap[interview.userId] }}</span>
              <span class="text-gray-400 text-xs ml-1">({{ interview.userId }})</span>
            {% else %}
              {{ interview.userId }}
            {% endif %}
          </td>
          <td class="py-1.5">
            {% if interview.sendStatus == 'SENT' or interview.sendStatus == 'DELIVERED' %}
            <span class="text-emerald-600 text-xs">已发送</span>
            {% elif interview.sendStatus == 'FAILED' %}
            <span class="text-red-600 text-xs" title="{{ interview.sendError or '' }}">发送失败</span>
            {% else %}
            <span class="text-gray-400 text-xs">未发送</span>
            {% endif %}
          </td>
          <td class="py-1.5">{{ interview.status }}</td>
          <td class="py-1.5">{{ interview.completedAt | date('Y-m-d H:i') or '-' }}</td>
          <td class="py-1.5 space-x-2">
            {% if interview.sendStatus == 'NOT_SENT' or interview.sendStatus == 'FAILED' %}
            <button
              hx-post="/api/plans/{{ plan.id }}/interviews/{{ interview.id }}/send"
              hx-target="#main-content"
              hx-swap="innerHTML"
              hx-confirm="确认向 {{ interview.userId }} 发送访谈邀约？"
              class="text-xs text-indigo-600 hover:underline"
            >发送</button>
            {% endif %}
            {% if interview.status != 'COMPLETED' and interview.status != 'CANCELLED' and (interview.sendStatus == 'SENT' or interview.sendStatus == 'DELIVERED') %}
            <button
              type="button"
              onclick="htmx.ajax('POST', '/api/plans/{{ plan.id }}/remind', { swap: 'none', values: { interviewId: '{{ interview.id }}' }, headers: { 'Content-Type': 'application/json', 'X-Admin-Key': '{{ adminApiKey | default('') }}' } }).then(function(xhr){ if(xhr.xhr && xhr.xhr.status>=200 && xhr.xhr.status<300){ htmx.ajax('GET','/admin/content/plans/{{ plan.id }}','#main-content'); } else { alert('提醒发送失败'); } })"
              class="text-xs text-amber-600 hover:underline"
            >提醒</button>
            {% endif %}
            {% if interview.status != 'COMPLETED' %}
            <button
              type="button"
              onclick="if(confirm('确认删除成员 {{ interview.userId }}？')){ htmx.ajax('DELETE', '/api/plans/{{ plan.id }}/members/{{ interview.id }}', { swap: 'none', headers: { 'Content-Type': 'application/json', 'X-Admin-Key': '{{ adminApiKey | default('') }}' } }).then(function(xhr){ if(xhr.xhr && xhr.xhr.status>=200 && xhr.xhr.status<300){ htmx.ajax('GET','/admin/content/plans/{{ plan.id }}','#main-content'); } else { alert('删除失败'); } }) }"
              class="text-xs text-red-600 hover:underline"
            >删除</button>
            {% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endif %}