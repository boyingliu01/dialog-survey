<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title | default('访谈管理后台') }}</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/htmx.org@2.0.4/dist/htmx.min.js" onerror="this.src='/js/htmx.min.js'"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js" onerror="this.src='/js/alpine.min.js'"></script>
  <style>
    [x-cloak] { display: none !important; }
    .tree-node { transition: background 0.12s; border-left: 2px solid transparent; }
    .tree-node:hover { background: #f1f5f9; border-left-color: #94a3b8; }
    .tree-node.selected { background: #e0e7ff; border-left-color: #6366f1; color: #4338ca; }
    .chevron { transition: transform 0.15s; }
    .chevron.rotated { transform: rotate(90deg); }
    .sidebar-scroll::-webkit-scrollbar { width: 5px; }
    .sidebar-scroll::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 3px; }
    .status-dot-PENDING { background: #9ca3af; }
    .status-dot-READY { background: #60a5fa; }
    .status-dot-RUNNING { background: #facc15; }
    .status-dot-PAUSED { background: #fb923c; }
    .status-dot-COMPLETED { background: #4ade80; }
    .status-dot-CANCELLED { background: #f87171; }
    .status-dot-ACTIVE { background: #facc15; }
    .status-dot-WAITING { background: #fb923c; }
  </style>
  <script>
    function toggleNode(defaultExpanded) {
      return { _expanded: defaultExpanded, toggle(node) { node._expanded = !node._expanded; } };
    }
  </script>
</head>
<body class="bg-gray-50 h-screen flex flex-col overflow-hidden" hx-headers='{"X-Admin-Key": "{{ adminApiKey | default('') }}"}'>
  <!-- Top bar -->
  <header class="bg-white border-b border-gray-200 flex-shrink-0 h-11 flex items-center px-4 gap-3">
    <span class="text-sm font-semibold text-gray-800">访谈管理后台</span>
    <a href="/" class="ml-auto text-xs text-gray-500 hover:text-gray-800">返回主站</a>
  </header>

  <div class="flex flex-1 overflow-hidden">
    <!-- Left Sidebar: Tree (server-rendered) -->
    <aside class="w-72 bg-white border-r border-gray-200 flex flex-col overflow-hidden">
      <div class="flex-1 overflow-y-auto sidebar-scroll px-1 py-2 text-sm">
        {% include "admin/tree-body.njk" %}
      </div>
    </aside>

    <!-- Right Content Area -->
    <main id="main-content" class="flex-1 overflow-y-auto relative">
      <!-- Loading indicator for HTMX content loads -->
      <div id="content-loading" class="hidden absolute inset-0 bg-white/60 z-10 flex items-center justify-center">
        <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-600"></div>
      </div>
      {% if content_html | default(false) %}
      <div class="p-6">{{ content_html | safe }}</div>
      {% else %}
      <div class="flex flex-col items-center justify-center h-full text-gray-400">
        <svg class="w-16 h-16 mb-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
        </svg>
        <p class="text-sm">点击左侧节点查看详情</p>
        <p class="text-xs mt-1 text-gray-300">模板 → 计划 → 访谈</p>
      </div>
      {% endif %}
    </main>
  </div>

  <!-- Global HTMX toast: errors (red) + success (green) -->
  <script>
  // Show/hide loading indicator for HTMX content loads
  document.body.addEventListener('htmx:beforeRequest', function(evt) {
    var loadingEl = document.getElementById('content-loading');
    if (loadingEl && evt.detail.target && evt.detail.target.id === 'main-content') {
      loadingEl.classList.remove('hidden');
      loadingEl.classList.add('flex');
    }
  });
  document.body.addEventListener('htmx:afterOnLoad', function(evt) {
    // Hide loading indicator
    var loadingEl = document.getElementById('content-loading');
    if (loadingEl) {
      loadingEl.classList.add('hidden');
      loadingEl.classList.remove('flex');
    }
    // Toast notifications
    var s = evt.detail.xhr.status;
    var txt = evt.detail.xhr.responseText;
    if (!txt) return;
    var isErr = s >= 400;
    var d = document.createElement('div'); d.innerHTML = txt;
    var msg = (d.textContent||d.innerText||'').trim().substring(0,150);
    if (!msg) return;
    var t = document.createElement('div');
    if (isErr) {
      t.className = 'fixed top-14 right-3 z-50 bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-2.5 rounded-lg shadow-lg max-w-xs';
    } else {
      t.className = 'fixed top-14 right-3 z-50 bg-green-50 border border-green-200 text-green-700 text-sm px-4 py-2.5 rounded-lg shadow-lg max-w-xs';
    }
    t.textContent = msg;
    document.body.appendChild(t);
    setTimeout(function(){t.remove()}, 3000);
  });

  // Scroll to error on form validation failure
  document.body.addEventListener('htmx:responseError', function(evt) {
    var errorEl = document.querySelector('#form-result .text-red-600, #plan-form-result .text-red-600');
    if (errorEl) {
      errorEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  });

  // Initialize Alpine in HTMX-loaded content
  document.addEventListener('htmx:afterSwap', function(evt) {
    if (typeof Alpine !== 'undefined') {
      Alpine.initTree(evt.detail.target);
    }
  });
  </script>
</body>
</html>
