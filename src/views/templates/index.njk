{% extends "layouts/admin.njk" %}

{% block content %}
<div class="flex justify-between items-center mb-6">
  <h2 class="text-2xl font-bold text-gray-900">模板列表</h2>
  <a href="/admin/templates/new"
     class="inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
    新建模板
  </a>
</div>

<div class="bg-white shadow overflow-hidden sm:rounded-lg">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">名称</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">状态</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">版本</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">访谈数</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">创建时间</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">操作</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200" id="templates-table-body">
      {% if templates and templates.length > 0 %}
        {% for template in templates %}
        <tr id="template-row-{{ template.id }}" class="hover:bg-gray-50">
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="text-sm font-medium text-gray-900">{{ template.name }}</div>
            {% if template.description %}
            <div class="text-sm text-gray-500 truncate max-w-xs">{{ template.description }}</div>
            {% endif %}
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            {% if template.status == 'PUBLISHED' %}
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                已发布
              </span>
            {% elif template.status == 'DRAFT' %}
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                草稿
              </span>
            {% elif template.status == 'ARCHIVED' %}
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                已归档
              </span>
            {% else %}
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                {{ template.status }}
              </span>
            {% endif %}
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            v{{ template.version | default(1) }}
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            {{ template.interviewCount | default(0) }}
            {% if template.activeCount > 0 %}
            <span class="text-xs text-blue-600">({{ template.activeCount | default(0) }} 进行中)</span>
            {% endif %}
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            {{ template.createdAt }}
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm font-medium space-x-2">
            <a href="/admin/templates/{{ template.id }}/edit"
               class="text-blue-600 hover:text-blue-900">编辑</a>
             <button type="button"
                     class="text-red-600 hover:text-red-900"
                     hx-delete="/admin/api/templates/{{ template.id }}"
                     hx-headers='{"X-Admin-Key": "{{ adminApiKey }}"}'
                     hx-confirm="确认删除模板「{{ template.name }}」？"
                     hx-target="closest tr"
                     hx-swap="outerHTML">删除</button>
          </td>
        </tr>
        {% endfor %}
      {% else %}
        <tr>
          <td colspan="6" class="px-6 py-12 text-center">
            <p class="text-gray-500 text-sm">暂无模板，点击"新建模板"创建第一个模板</p>
          </td>
        </tr>
      {% endif %}
    </tbody>
  </table>
</div>

{% if pagination and pagination.totalPages > 1 %}
<div class="mt-6 flex justify-between items-center">
  <p class="text-sm text-gray-700">
    显示第 {{ ((pagination.page - 1) * pagination.pageSize) + 1 }} - {{ pagination.page * pagination.pageSize }} 条，共 {{ pagination.totalCount }} 条
  </p>
  <nav class="flex space-x-2">
    {% if pagination.page > 1 %}
    <a href="?page={{ pagination.page - 1 }}"
       class="px-3 py-1 text-sm border border-gray-300 rounded hover:bg-gray-50">
      上一页
    </a>
    {% endif %}

    {% for p in range(1, pagination.totalPages + 1) %}
      {% if p == pagination.page %}
        <span class="px-3 py-1 text-sm bg-blue-600 text-white rounded">{{ p }}</span>
      {% elif p == 1 or p == pagination.totalPages or (p >= pagination.page - 1 and p <= pagination.page + 1) %}
        <a href="?page={{ p }}"
           class="px-3 py-1 text-sm border border-gray-300 rounded hover:bg-gray-50">
          {{ p }}
        </a>
      {% elif p == pagination.page - 2 or p == pagination.page + 2 %}
        <span class="px-1 text-sm text-gray-400">...</span>
      {% endif %}
    {% endfor %}

    {% if pagination.page < pagination.totalPages %}
    <a href="?page={{ pagination.page + 1 }}"
       class="px-3 py-1 text-sm border border-gray-300 rounded hover:bg-gray-50">
      下一页
    </a>
    {% endif %}
  </nav>
</div>
{% endif %}

<div id="delete-modal-container"></div>
{% endblock %}
