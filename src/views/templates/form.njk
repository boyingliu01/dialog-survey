{% extends "layouts/admin.njk" %}

{% block content %}
<div class="mb-6">
  <h2 class="text-2xl font-bold text-gray-900">
    {% if isEdit %}编辑模板{% else %}新建模板{% endif %}
  </h2>
</div>

<div x-data="{
  questions: {{ existingQuestions | dump | replace('"', '&quot;') | safe }},
  addQuestion() {
    this.questions.push({ text: '', order: this.questions.length });
  },
  removeQuestion(index) {
    this.questions.splice(index, 1);
    this.questions.forEach((q, i) => q.order = i);
  },
  moveUp(index) {
    if (index === 0) return;
    const temp = this.questions[index];
    this.questions[index] = this.questions[index - 1];
    this.questions[index - 1] = temp;
    this.questions = [...this.questions];
    this.questions.forEach((q, i) => q.order = i);
  },
  moveDown(index) {
    if (index === this.questions.length - 1) return;
    const temp = this.questions[index];
    this.questions[index] = this.questions[index + 1];
    this.questions[index + 1] = temp;
    this.questions = [...this.questions];
    this.questions.forEach((q, i) => q.order = i);
  }
}" class="bg-white shadow sm:rounded-lg">
  <form
    {% if isEdit %}
    hx-put="/admin/api/templates/{{ template.id }}"
    {% else %}
    hx-post="/admin/api/templates"
    {% endif %}
    hx-target="#form-result"
    hx-swap="innerHTML"
    hx-indicator="#submit-btn"
    class="divide-y divide-gray-200"
  >
    {% if isEdit %}
    <input type="hidden" name="version" value="{{ template.version | default(1) }}" />
    {% endif %}

    <div class="p-6 space-y-6">
      <div>
        <label for="name" class="block text-sm font-medium text-gray-700">
          名称 <span class="text-red-500">*</span>
        </label>
        <input type="text" id="name" name="name" required
               value="{{ template.name | default('') }}"
               class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border"
               placeholder="请输入模板名称" />
      </div>

      <div>
        <label for="description" class="block text-sm font-medium text-gray-700">
          描述
        </label>
        <textarea id="description" name="description" rows="2"
                  class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border"
                  placeholder="模板用途说明（可选）">{{ template.description | default('') }}</textarea>
      </div>

      <div>
        <label for="invitationPrompt" class="block text-sm font-medium text-gray-700">
          邀约提示词 <span class="text-red-500">*</span>
        </label>
        <textarea id="invitationPrompt" name="invitationPrompt" required rows="3"
                  class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border"
                  placeholder="输入用于邀约候选人的AI提示词">{{ template.invitationPrompt | default('') }}</textarea>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">
          问题列表
        </label>
        <template x-for="(question, index) in questions" :key="index">
          <div class="flex items-start space-x-2 mb-2">
            <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-gray-100 text-xs text-gray-600 flex-shrink-0 mt-2" x-text="index + 1"></span>
            <textarea :name="`questions[${index}][text]`"
                      x-model="question.text"
                      rows="2"
                      class="flex-1 rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border"
                      placeholder="请输入问题内容"></textarea>
            <div class="flex flex-col space-y-1 pt-2">
              <button type="button" @click="moveUp(index)" :disabled="index === 0"
                      class="text-xs text-gray-500 hover:text-gray-700 disabled:opacity-30"
                      title="上移">↑</button>
              <button type="button" @click="moveDown(index)" :disabled="index === questions.length - 1"
                      class="text-xs text-gray-500 hover:text-gray-700 disabled:opacity-30"
                      title="下移">↓</button>
              <button type="button" @click="removeQuestion(index)"
                      class="text-xs text-red-500 hover:text-red-700"
                      title="删除">×</button>
            </div>
          </div>
        </template>
        <button type="button" @click="addQuestion()"
                class="mt-2 inline-flex items-center text-sm text-blue-600 hover:text-blue-800">
          + 添加问题
        </button>
      </div>

      <div>
        <label for="closingMessage" class="block text-sm font-medium text-gray-700">
          结束语
        </label>
        <textarea id="closingMessage" name="closingMessage" rows="2"
                  class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border"
                  placeholder="访谈结束时的结束语（可选）">{{ template.closingMessage | default('') }}</textarea>
      </div>

      <div>
        <label for="llmPromptTemplate" class="block text-sm font-medium text-gray-700">
          <span>智能提示词模板</span>
          <span class="text-gray-400 font-normal ml-1">(可选，留空则使用系统默认值)</span>
        </label>
        <div class="mt-1 flex space-x-2">
          <textarea id="llmPromptTemplate" name="llmPromptTemplate" rows="12"
                    class="flex-1 rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border font-mono text-sm"
                    placeholder="自定义 AI 主持人的提示词模板。支持变量：{{conversationHistory}}, {{currentQuestion}}, {{followupCount}}, {{maxFollowups}}, {{userAnswer}}, {{userName}}, {{lastQuestionFlag}}">{{ template.llmPromptTemplate | default('') }}</textarea>
        </div>
        <p class="mt-1 text-xs text-gray-500">
          可用变量：<code class="bg-gray-100 px-1 rounded">conversationHistory</code>
          <code class="bg-gray-100 px-1 rounded">currentQuestion</code>
          <code class="bg-gray-100 px-1 rounded">followupCount</code>
          <code class="bg-gray-100 px-1 rounded">maxFollowups</code>
          <code class="bg-gray-100 px-1 rounded">userAnswer</code>
          <code class="bg-gray-100 px-1 rounded">userName</code>
          <code class="bg-gray-100 px-1 rounded">lastQuestionFlag</code>
        </p>
        <button type="button" id="restore-default-prompt"
                class="mt-2 inline-flex items-center text-sm text-amber-600 hover:text-amber-800"
                onclick="document.getElementById('llmPromptTemplate').value = document.getElementById('llmPromptTemplate').value === '' ? '' : window.defaultPromptTemplate; this.classList.replace('text-amber-600','text-green-600'); this.textContent = '已恢复'; setTimeout(()=>{this.classList.replace('text-green-600','text-amber-600'); this.textContent='恢复默认提示词';}, 1500); return false;">
          恢复默认提示词
        </button>
      </div>
    </div>

    <div class="px-6 py-4 bg-gray-50 flex justify-end space-x-3">
      <a href="/admin"
         class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
        取消
      </a>
      <button type="submit" id="submit-btn"
              class="inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50">
        <span class="htmx-indicator hidden mr-2">
          <svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </span>
        {% if isEdit %}保存更改{% else %}创建模板{% endif %}
      </button>
    </div>
  </form>

  <div id="form-result" class="px-6 pb-4"></div>
</div>
{% endblock %}
