# Interview Bot — Production Environment Template
# Copy to .env.production on the target server and fill in actual values.
# Usage: cp .env.production.example .env.production

# ── Server Configuration ─────────────────────────────────────
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# ── Database ──────────────────────────────────────────────────
# PostgreSQL connection string. Production recommendations:
#   - Use a dedicated database user (not postgres superuser)
#   - Enable SSL if your provider supports it (add ?sslmode=require)
#   - Connection pooling: pgBouncer recommended for >50 concurrent connections
DATABASE_URL="postgresql://user:password@localhost:5432/interview_bot?schema=public"

# ── LLM Configuration ───────────────────────────────────────
DASHSCOPE_API_KEY=your-dashscope-api-key
MAX_LLM_RETRIES=2
LLM_TIMEOUT=30000

# ── DingTalk Stream Mode Configuration ───────────────────────
# For production, use Stream Mode (WebSocket) instead of webhook polling
DINGTALK_CLIENT_ID=your-dingtalk-client-id
DINGTALK_CLIENT_SECRET=your-dingtalk-client-secret
DINGTALK_AGENT_ID=your-dingtalk-agent-id

# Legacy webhook (deprecated — use Stream Mode above)
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx
DINGTALK_SECRET=your-dingtalk-webhook-secret
DINGTALK_APP_KEY=your-dingtalk-app-key
DINGTALK_APP_SECRET=your-dingtalk-app-secret

# Public callback URL for DingTalk webhooks (if not using Stream Mode)
PUBLIC_URL=https://your-public-url.com

# ── Speech Recognition ───────────────────────────────────────
FUN_ASR_API_KEY=your-fun-asr-api-key

# ── Security ──────────────────────────────────────────────────
# Generate ENCRYPTION_KEY: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-encryption-key-hex
ADMIN_API_KEY=your-strong-admin-api-key

# ── Report Configuration ─────────────────────────────────────
REPORTS_DIR=./reports

# ── Logging ───────────────────────────────────────────────────
# Production: info, warn, error only. Use debug for troubleshooting.
LOG_LEVEL=info
