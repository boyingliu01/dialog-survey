generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InterviewStatus {
  PENDING
  ACTIVE
  WAITING
  COMPLETED
  CANCELLED
}

enum TemplateStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Interview {
  id              String          @id @default(uuid())
  userId          String
  templateId      String
  planId          String?
  status          InterviewStatus @default(PENDING)
  currentQuestion Int              @default(0)
  followupCount   Int              @default(0)
  maxFollowups    Int              @default(2)
  version         Int              @default(1) // Optimistic locking
  startedAt       DateTime?
  completedAt     DateTime?
  reportPath      String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  messages     Message[]
  responses    Response[]
  plan         InterviewPlan? @relation(fields: [planId], references: [id])
  template     Template        @relation(fields: [templateId], references: [id])
  reports      AnalysisReport[]
}

model Message {
  id            String   @id @default(uuid())
  interviewId   String
  role          String
  content       String
  messageId     String?
  isVoice       Boolean  @default(false)
  voiceText     String?
  createdAt     DateTime @default(now())

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
}

model Response {
  id           String   @id @default(uuid())
  interviewId  String
  questionId   String
  content      String
  isFollowup   Boolean  @default(false)
  followupDepth Int     @default(0)
  createdAt    DateTime @default(now())

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
}

model Template {
  id          String         @id @default(uuid())
  name        String
  description String?
  content     String         // JSON string
  version     Int            @default(1)
  status      TemplateStatus @default(DRAFT)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  interviews    Interview[]
  interviewPlans InterviewPlan[]
}

model InterviewPlan {
  id            String    @id @default(uuid())
  name          String
  description   String?
  templateId    String
  targetDate    DateTime?
  status        PlanStatus @default(PENDING)
  schedule      String?   // Cron expression for scheduling
  inviteeData   Json?     // Imported interviewee data (JSON)
  sentCount     Int       @default(0)
  completedCount Int      @default(0)
  failedCount   Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  startedAt     DateTime?
  completedAt   DateTime?

  interviews Interview[]
  template   Template   @relation(fields: [templateId], references: [id])
}

enum PlanStatus {
  PENDING
  READY
  RUNNING
  PAUSED
  COMPLETED
  CANCELLED
}

model AnalysisReport {
  id          String   @id @default(uuid())
  interviewId String
  content     String
  keyFindings String[]
  sentiment   String?
  recommendations String[]
  createdAt   DateTime @default(now())

  interview Interview? @relation(fields: [interviewId], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String?
  userId     String?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())
}