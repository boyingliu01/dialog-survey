{
  "name": "dialog-survey",
  "version": "1.7.3",
  "type": "module",
  "description": "AI-powered interview robot that conducts async multi-turn interviews via DingTalk",
  "repository": {
    "type": "git",
    "url": "https://github.com/boyingliu01/dialog-survey"
  },
  "files": ["dist/", "scripts/", "src/views/", "public/", "prisma/", "ecosystem.config.cjs"],
  "bin": {
    "dialog-survey": "scripts/cli.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx --env-file=.env --watch src/server.ts",
    "build": "tsc",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "type-check": "tsc --noEmit",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "lint:prisma": "ast-grep scan --rule .ast-grep/rules/no-raw-prisma-in-api.yml",
    "start": "node dist/src/server.js",
    "deploy": "bash scripts/deploy.sh"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/static": "^9.1.3",
    "@fastify/view": "^11.1.1",
    "@fastify/websocket": "^11.2.0",
    "@langchain/core": "^1.1.37",
    "@langchain/langgraph": "^1.2.6",
    "@prisma/adapter-pg": "^5.22.0",
    "@prisma/client": "5.22.0",
    "csv-parse": "^7.0.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.4",
    "fastify-type-provider-zod": "^6.1.0",
    "marked": "^14.1.4",
    "node-cron": "^4.2.1",
    "nunjucks": "^3.2.4",
    "p-limit": "^5.0.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.61.0",
    "ws": "^8.20.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.43.0",
    "@biomejs/biome": "^1.9.4",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^20.12.0",
    "@types/node-cron": "^3.0.11",
    "@types/nunjucks": "^3.2.6",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.2",
    "jscpd": "^4.2.4",
    "prisma": "5.22.0",
    "tsx": "^4.7.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "qs": "6.15.2"
  }
}
