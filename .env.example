# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/interview_bot?schema=public"

# LLM Configuration
DASHSCOPE_API_KEY=your-dashscope-api-key
MAX_LLM_RETRIES=2
LLM_TIMEOUT=30000

# DingTalk Configuration
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx
DINGTALK_SECRET=your-dingtalk-webhook-secret
DINGTALK_APP_KEY=your-dingtalk-app-key
DINGTALK_APP_SECRET=your-dingtalk-app-secret
DINGTALK_AGENT_ID=your-dingtalk-agent-id
PUBLIC_URL=https://your-public-url.com

# Fun-ASR Configuration
FUN_ASR_API_KEY=your-fun-asr-api-key

# Security
ENCRYPTION_KEY=your-32-byte-encryption-key-hex

# Report Configuration
REPORTS_DIR=./reports

# Logging
LOG_LEVEL=info
