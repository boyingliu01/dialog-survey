# Server Configuration
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/dialog_survey?schema=public"

# LLM Configuration (OpenAI-compatible — works with ollama, vLLM, LocalAI, or cloud)
# LLM_BASE_URL should be the full chat completions endpoint URL
# LLM_BASE_URL=http://localhost:11434/v1/chat/completions
LLM_API_KEY=your-llm-api-key
LLM_MODEL=qwen2.5
# Alternatively, use Volcengine Ark (fallback when LLM_ prefix not set):
# VOLCENGINE_API_KEY=your-volcengine-api-key
# VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v1/chat/completions
# VOLCENGINE_MODEL=deepseek-v3.2
MAX_LLM_RETRIES=2
LLM_TIMEOUT=30000

# DingTalk Configuration
DINGTALK_CLIENT_ID=your-dingtalk-client-id
DINGTALK_CLIENT_SECRET=your-dingtalk-client-secret
DINGTALK_AGENT_ID=your-dingtalk-agent-id
DINGTALK_APP_KEY=your-dingtalk-app-key
DINGTALK_APP_SECRET=your-dingtalk-app-secret
DINGTALK_AGENT_ID=your-dingtalk-agent-id
PUBLIC_URL=https://your-public-url.com

# Fun-ASR Configuration
FUN_ASR_API_KEY=your-fun-asr-api-key

# Security
ENCRYPTION_KEY=your-32-byte-encryption-key-hex
ADMIN_API_KEY=your-admin-api-key

# Report Configuration
REPORTS_DIR=./reports

# Logging
LOG_LEVEL=info
